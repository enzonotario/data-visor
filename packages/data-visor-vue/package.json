{
  "name": "data-visor-vue",
  "type": "module",
  "version": "0.0.1",
  "description": "Data Visor — JSON/YAML/XML viewer for Vue 3, powered by Shiki",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enzonotario/data-visor.git",
    "directory": "packages/data-visor-vue"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./style.css": "./dist/style.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "fast-xml-parser": "^5.5.9",
    "shiki": "^4.0.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@unocss/postcss": "^66.6.7",
    "@tsdown/css": "^0.21.7",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/core": "^14.2.1",
    "happy-dom": "^20.8.4",
    "postcss": "^8.5.6",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "unocss": "^66.6.7",
    "unplugin-vue": "^7.1.1",
    "vitest": "^4.1.0",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.6"
  }
}
